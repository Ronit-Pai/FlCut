generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Link {
  id          String       @id @default(uuid())
  slug        String       @unique
  targetUrl   String
  goLiveAt    DateTime?
  expiresAt   DateTime?
  isDisabled  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  clickEvents ClickEvent[]

  @@index([createdAt])
  @@index([goLiveAt])
  @@index([expiresAt])
  @@map("links")
}

model ClickEvent {
  id         String   @id @default(uuid())
  linkId     String
  ipHash     String?
  userAgent  String?
  deviceType String?
  referrer   String?
  country    String?
  createdAt  DateTime @default(now())
  link       Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([createdAt])
  @@index([ipHash])
  @@index([deviceType])
  @@map("click_events")
}

model ReservedSlug {
  id        String   @id @default(uuid())
  slug      String   @unique
  reason    String?
  createdAt DateTime @default(now())

  @@map("reserved_slugs")
}
